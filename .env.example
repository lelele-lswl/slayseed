# ============================================
#  Slay Seed 环境变量示例
#  复制此文件为 .env 并修改其中的值
#  ⚠️ .env 文件包含敏感信息，绝不能提交到版本控制！
# ============================================

# --- 通用 ---
TZ=Asia/Shanghai

# --- MySQL 数据库（必须修改密码！）---
MYSQL_ROOT_PASSWORD=your-root-password-here
MYSQL_DATABASE=slayseed
MYSQL_USER=slayseed
MYSQL_PASSWORD=your-user-password-here
MYSQL_PORT=3306

# --- Redis（必须修改密码！）---
REDIS_PASSWORD=your-redis-password-here
REDIS_PORT=6379

# --- 后端（必须修改 JWT_SECRET！）---
SERVER_PORT=8080
JWT_SECRET=your-jwt-secret-key-at-least-32-chars
JWT_EXPIRATION=86400000

# --- 前端 ---
FRONTEND_PORT=80

# --- CORS 允许的源（生产环境请设置具体域名）---
CORS_ALLOWED_ORIGINS=*

# --- Docker 镜像仓库（生产部署用）---
IMAGE_REGISTRY=registry.cn-hangzhou.aliyuncs.com
IMAGE_TAG=latest

# --- 服务器部署 IP ---
SERVER_IP=your-server-ip-here